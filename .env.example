# 大语言模型配置 (支持OpenAI, DeepSeek等兼容OpenAI接口的模型)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 运行配置
# 定时任务表达式，例如 "0 9,20 * * *" 表示每天早9点和晚8点执行
CRON_EXPRESSION="0 9,20 * * *"

# message hook
# 是否启用钉钉推送 (true/false)
ENABLE_DINGTALK=true
dingtalk_hook=https://oapi.dingtalk.com/robot/send?access_token=your_dingtalk_access_token_here
dingtalk_secret=your_dingtalk_secret_here

# telegram配置
# 是否启用Telegram推送 (true/false)
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
